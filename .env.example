PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT (admin auth)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Admin seed account (used by createAdmin.js script only)
ADMIN_EMAIL=admin@oclabotanicals.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=OCLA Admin

# Frontend (used for CORS, email links, and Dodo redirect URLs — include trailing slash)
FRONTEND_URL=https://www.oclabotanicals.com/

# Resend (https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=OCLA Botanical <orders@oclabotanicals.com>

# Dodo Payments (https://dodopayments.com → Developer → API Keys)
DODO_API_KEY=dodo_live_xxxxxxxxxxxxxxxxxxxx
DODO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Test: https://test.dodopayments.com  |  Live: https://live.dodopayments.com
DODO_BASE_URL=https://test.dodopayments.com

# ImageKit (https://imagekit.io → Settings → Developer options)
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
